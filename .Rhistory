group     = group_name,
# Individual baseline tendency (random effect)
ind_effect = rnorm(n_mice, mean = 0, sd = between_mouse_sd),
# Novel object exploration (longer, more variable)
novel_time = rgamma(n_mice,
shape = (novel_mean + ind_effect)^2 / 15^2,
rate  = (novel_mean + ind_effect) / 15^2) |>
pmax(5) |> pmin(trial_duration * 0.6),
# Familiar object (shorter)
familiar_time = rgamma(n_mice,
shape = (familiar_mean + ind_effect)^2 / 10^2,
rate  = (familiar_mean + ind_effect) / 10^2) |>
pmax(2) |> pmin(trial_duration * 0.4),
# Discrimination index: (novel - familiar) / total
discrimination_index = (novel_time - familiar_time) /
(novel_time + familiar_time) * 100
) |> select(-ind_effect)
# --- Simulate ---
simulate_nor_data <- function(n_mice, group_name,
novel_mean, familiar_mean,
between_mouse_sd = 2) {
tibble(
mouse_id  = paste0(group_name, "_M", seq_len(n_mice)),
group     = group_name,
# Individual baseline tendency (random effect)
ind_effect = rnorm(n_mice, mean = 0, sd = between_mouse_sd),
# Novel object exploration (longer, more variable)
novel_time = rgamma(n_mice,
shape = (novel_mean + ind_effect)^2 / 15^2,
rate  = (novel_mean + ind_effect) / 15^2) |>
pmax(5) |> pmin(trial_duration * 0.6),
# Familiar object (shorter)
familiar_time = rgamma(n_mice,
shape = (familiar_mean + ind_effect)^2 / 10^2,
rate  = (familiar_mean + ind_effect) / 10^2) |>
pmax(2) |> pmin(trial_duration * 0.4),
# Discrimination index: (novel - familiar) / total
discrimination_index = (novel_time - familiar_time) /
(novel_time + familiar_time) * 100
) |> select(-ind_effect)
}
data_control <- simulate_nor_data(n_mice, "Control",
novel_mean = 10, familiar_mean = 8)
data_treat   <- simulate_nor_data(n_mice, "Treatment",
novel_mean = 12, familiar_mean = 6)
nor_data <- bind_rows(data_control, data_treat)
View(nor_data)
View(nor_data)
rm(list = data_control, data_treat)
rm(list = (data_control, data_treat))
View(data_control)
View(data_control)
rm(list = data_control)
rm(data_control)
rm(data_treat)
# --- Simulate ---
simulate_nor_data <- function(n_mice, group_name,
novel_mean, familiar_mean,
between_mouse_sd = 2) {
tibble(
mouse_id  = paste0(group_name, "_M", seq_len(n_mice)),
group     = group_name,
# Individual baseline tendency (random effect)
ind_effect = rnorm(n_mice, mean = 0, sd = between_mouse_sd),
# Novel object exploration (longer, more variable)
novel_time = rgamma(n_mice,
shape = (novel_mean + ind_effect)^2 / 15^2,
rate  = (novel_mean + ind_effect) / 15^2) |>
pmax(5) |> pmin(trial_duration * 0.6),
# Familiar object (shorter)
familiar_time = rgamma(n_mice,
shape = (familiar_mean + ind_effect)^2 / 10^2,
rate  = (familiar_mean + ind_effect) / 10^2) |>
pmax(2) |> pmin(trial_duration * 0.4),
# Discrimination index: (novel - familiar) / total
discrimination_index = (novel_time - familiar_time) /
(novel_time + familiar_time) * 100
) |> select(-ind_effect)
}
data_control <- simulate_nor_data(n_mice, "Control",
novel_mean = 10, familiar_mean = 8)
data_treat   <- simulate_nor_data(n_mice, "Treatment",
novel_mean = 12, familiar_mean = 6)
nor_data <- bind_rows(data_control, data_treat)
View(nor_data)
